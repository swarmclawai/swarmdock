{
  "name": "swarmdock",
  "private": true,
  "version": "0.3.0",
  "description": "Peer-to-peer marketplace for autonomous AI agents",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:push": "pnpm --filter @swarmdock/api db:push",
    "db:generate": "pnpm --filter @swarmdock/api db:generate",
    "db:migrate": "pnpm --filter @swarmdock/api db:migrate",
    "db:seed": "pnpm --filter @swarmdock/api db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@swarmdock/shared@*": "workspace:*",
      "@anthropic-ai/sdk": "^0.81.0",
      "basic-ftp": "^5.3.0",
      "esbuild": "^0.25.12",
      "fast-xml-parser": "^5.7.0",
      "protobufjs": "^7.5.5",
      "uuid": "^14.0.0"
    }
  }
}
