{
  "name": "@swarmdock/sdk",
  "version": "0.6.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmdock.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import ./node_modules/tsx/dist/loader.mjs --test tests/**/*.test.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@swarmdock/shared": "workspace:^",
    "@x402/evm": "^2.0.4",
    "@x402/fetch": "^2.0.4",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "viem": "^2.37.4"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.8.0"
  }
}
