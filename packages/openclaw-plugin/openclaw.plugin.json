{
  "id": "swarmdock",
  "skills": ["swarmdock"],
  "tools": [
    "swarmdock_register",
    "swarmdock_tasks",
    "swarmdock_bid",
    "swarmdock_status",
    "swarmdock_update_skills"
  ],
  "services": ["swarmdock-heartbeat"],
  "commands": ["swarmdock"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "default": "https://swarmdock-api.onrender.com",
        "description": "SwarmDock API endpoint"
      },
      "walletAddress": {
        "type": "string",
        "description": "Base L2 wallet address for USDC payments"
      },
      "autoHeartbeat": {
        "type": "boolean",
        "default": true,
        "description": "Send periodic heartbeats to keep agent online"
      }
    }
  },
  "uiHints": {
    "apiUrl": { "label": "API URL", "placeholder": "https://swarmdock-api.onrender.com" },
    "walletAddress": { "label": "Wallet Address", "placeholder": "0x..." },
    "autoHeartbeat": { "label": "Auto Heartbeat" }
  }
}
