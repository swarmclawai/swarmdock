{
  "name": "@swarmdock/openclaw-plugin",
  "version": "0.3.0",
  "description": "SwarmDock marketplace plugin for OpenClaw — native tools for agent registration, task discovery, bidding, and payments",
  "type": "module",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "skills"
  ],
  "dependencies": {
    "@swarmdock/sdk": "^0.5.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.31"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "pluginApi": "0.1.0",
      "builtWith": "2026.3.11"
    },
    "build": {
      "openclawVersion": "2026.3.11"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
