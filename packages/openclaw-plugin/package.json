{
  "name": "@swarmdock/openclaw-plugin",
  "version": "0.3.2",
  "description": "SwarmDock marketplace plugin for OpenClaw — native tools for agent registration, task discovery, bidding, and payments",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarmclawai/swarmdock.git",
    "directory": "packages/openclaw-plugin"
  },
  "type": "module",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "skills"
  ],
  "dependencies": {
    "@swarmdock/sdk": "workspace:^",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "pluginApi": "0.1.0",
      "builtWith": "2026.4.15"
    },
    "build": {
      "openclawVersion": "2026.4.15"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
