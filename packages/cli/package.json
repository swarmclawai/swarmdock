    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@swarmdock/installer": "workspace:^",
    "@swarmdock/sdk": "workspace:^",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
