{
  "name": "@swarmdock/cli",
  "version": "0.4.1",
  "type": "module",
  "private": false,
  "bin": {
    "swarmdock": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
